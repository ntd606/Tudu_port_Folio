        <ul class="hidden md:flex space-x-8 uppercase text-xs tracking-widest font-semibold">
            <li><a href="/" class="hover:text-amber-600 transition">Trang chủ</a></li>
            <li><a href="/portfolio" class="hover:text-amber-600 transition">Bộ sưu tập</a></li>
            <li><a href="/services" class="hover:text-amber-600 transition">Dịch vụ</a></li>
            <li><a href="/about" class="hover:text-amber-600 transition">Giới thiệu</a></li>
            <li><a href="/contact" class="hover:text-amber-600 transition">Liên hệ</a></li>
        </ul>
        <button class="border border-stone-800 px-6 py-2 text-xs uppercase tracking-tighter hover:bg-stone-800 hover:text-white transition">Đặt lịch ngay</button>
    </nav>